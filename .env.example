# ═══════════════════════════════════════════════════════════════════════════════
# AgentOS — Environment Configuration Reference
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Variables marked [REQUIRED] must be set before running.
# Variables marked [OPTIONAL] have sensible defaults.
# ═══════════════════════════════════════════════════════════════════════════════

# ── APP ──────────────────────────────────────────────────────────────────────
# Application runtime settings
# [OPTIONAL] str — Directory for per-task sandboxed workspaces
WORKSPACE_DIR=./workspace

# [OPTIONAL] list<str> — Comma-separated CORS allowed origins
# ⚠️ DANGER: Never set to "*" in production — allows any origin
ALLOWED_ORIGINS=http://localhost:3000

# [OPTIONAL] int (1-32) — Maximum concurrent agent threads per worker
MAX_WORKERS=4

# [OPTIONAL] int (1-100) — Backpressure limit: max tasks in CREATED/RUNNING state
MAX_CONCURRENT_TASKS=10

# [OPTIONAL] int (30-3600) — Hard kill timeout per Celery task in seconds
TASK_TIMEOUT_SECONDS=600

# [OPTIONAL] int (1-1000) — API rate limit: requests per minute per IP
RATE_LIMIT_RPM=10

# ── DATABASE ─────────────────────────────────────────────────────────────────
# [OPTIONAL] str — SQLAlchemy connection string
# ⚠️ DANGER: Contains credentials — never commit actual values
# SQLite: sqlite:///./saas_backend.db
# PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./saas_backend.db

# ── REDIS ────────────────────────────────────────────────────────────────────
# [REQUIRED] str — Redis connection URL for Celery broker + result backend
# ⚠️ DANGER: If using auth, URL contains password
REDIS_URL=redis://localhost:6379/0

# ── LLM (Ollama) ────────────────────────────────────────────────────────────
# [OPTIONAL] str — Ollama generate API endpoint
OLLAMA_URL=http://localhost:11434/api/generate

# [OPTIONAL] str — Ollama tags API endpoint (model listing)
OLLAMA_TAGS_URL=http://localhost:11434/api/tags

# [OPTIONAL] str — Default model for inference
OLLAMA_MODEL=deepseek-coder:1.3b

# [OPTIONAL] str — Model used in development mode
DEV_MODE_MODEL=deepseek-coder:1.3b

# [OPTIONAL] str — Model used in production mode
PROD_MODE_MODEL=deepseek-coder:6.7b

# [OPTIONAL] int — Context window size in tokens
OLLAMA_NUM_CTX=2048

# [OPTIONAL] int (seconds) — Timeout waiting for model to load
OLLAMA_LOAD_TIMEOUT=120

# [OPTIONAL] int (seconds) — Timeout per token generation
OLLAMA_TOKEN_TIMEOUT=30

# [OPTIONAL] str — How long Ollama keeps model in memory
OLLAMA_KEEP_ALIVE=30m

# [OPTIONAL] int (seconds) — Maximum total timeout for an LLM call
OLLAMA_MAX_TOTAL_TIMEOUT=600

# ── CELERY ───────────────────────────────────────────────────────────────────
# [OPTIONAL] str — Celery broker URL (defaults to REDIS_URL)
CELERY_BROKER_URL=${REDIS_URL}

# [OPTIONAL] str — Celery result backend (defaults to REDIS_URL)
CELERY_RESULT_BACKEND=${REDIS_URL}

# ── RESOURCE CAPS ────────────────────────────────────────────────────────────
# [OPTIONAL] int (bytes) — Maximum file size for generated code files
MAX_FILE_BYTES=1048576

# [OPTIONAL] int (bytes) — Maximum log bytes per task
MAX_LOG_BYTES_PER_TASK=2097152

# [OPTIONAL] int (MB) — Maximum workspace disk usage before pruning
MAX_WORKSPACE_DISK_MB=2048

# ── OBSERVABILITY ────────────────────────────────────────────────────────────
# [OPTIONAL] str — Log level (DEBUG|INFO|WARNING|ERROR|CRITICAL)
LOG_LEVEL=INFO

# [OPTIONAL] str — Flower monitoring credentials (user:pass)
FLOWER_USER=admin
# ⚠️ DANGER: Change this before exposing Flower externally
FLOWER_PASSWORD=changeme

# ── CI/CD SECRETS (set in GitHub Secrets, not in .env) ───────────────────────
# GITHUB_TOKEN         — Auto-provided by GitHub Actions for GHCR push
# CODECOV_TOKEN        — Token from codecov.io for coverage upload
# SLACK_WEBHOOK_URL    — Incoming webhook for deployment notifications
# STAGING_SSH_KEY      — SSH key for staging server deployment (if applicable)
# PRODUCTION_SSH_KEY   — SSH key for production server deployment (if applicable)
