# ═══════════════════════════════════════════════════════════════════════════════
# AgentOS — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.installed.cfg
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-link
*.pth
pip-wheel-metadata/
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.env.local
.env.production
# Note: .env is intentionally gitignored — use .env.example as template
.env

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
reports/
test-results/
*.xml
!pyproject.toml

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ── Linting & Formatting ─────────────────────────────────────────────────────
.ruff_cache/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
fastapi.log
celery_log.txt
uvicorn_log.txt
logs/

# ── Database files ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
# Alembic migration versions are committed — but not generated runtime files
dump.rdb

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
.npm
.next/
out/
frontend/.next/
frontend/out/
frontend/node_modules/
*.tsbuildinfo
next-env.d.ts

# ── IDE and editor files ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.directory

# ── Benchmarks & local test output ───────────────────────────────────────────
.benchmarks/
benchmark-results/

# ── Workspace (generated task files, not source code) ─────────────────────────
# The workspace/ folder is runtime output, not tracked in git.
# Commit workspace/workspace_map.json only if needed for fixtures.
workspace/*
!workspace/workspace_map.json

# ── Secrets baseline (generated by detect-secrets) ───────────────────────────
# Re-generate with: detect-secrets scan > .secrets.baseline
.secrets.baseline

# ── Celery ────────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── ChromaDB local store ──────────────────────────────────────────────────────
chroma_data/
.chroma/

# ── Profiling ────────────────────────────────────────────────────────────────
*.prof
*.lprof
